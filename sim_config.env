# =============================================================
#  模拟器 & 批量加载器 统一配置
#  run_sim.sh 和 imu_raw_db.py 都从这里读取
# =============================================================

# ── TDengine 连接 ──────────────────────────────────────────
TD_HOST=127.0.0.1
TD_PORT=6041
TD_USER=root
TD_PASS=taosdata
TD_DB=pet_collar_raw

# ── PostgreSQL 连接 ────────────────────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=123456
PG_DB=pet_collar

# ── IMU 采样率 ─────────────────────────────────────────────
#  可选值：25 / 50
IMU_SAMPLE_HZ=50

# ── 环境 & 颈温采样间隔（秒）─────────────────────────────
ENV_SAMPLE_INTERVAL=60
NECK_SAMPLE_INTERVAL=60

# ── 实时模拟器窗口设置 ─────────────────────────────────────
#  WINDOW_MINUTES : 每批数据窗口时长，可选 15 / 30 / 60
WINDOW_MINUTES=15

#  WINDOW_SEC : 每个模拟窗口等待多少真实秒（测试加速用）
#               生产环境（不加速）：WINDOW_SEC=$((WINDOW_MINUTES * 60))
WINDOW_SEC=15

#  WINDOWS_PER_DAY : 多少个窗口合计为 1 个模拟天
#                    15min -> 96，30min -> 48，60min -> 24
#                    测试时可设小一些（如 12）快速看到每日评估
WINDOWS_PER_DAY=12

#  SICK_START_DAY : sim_device_sick 在第几模拟天开始出现皮肤异常
SICK_START_DAY=5
